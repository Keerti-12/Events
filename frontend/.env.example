# Frontend Environment Variables Example
# Copy this file to .env and fill in the values

# API URL (leave empty for same-origin proxy in development)
VITE_API_URL=

# For production, use your API URL
# VITE_API_URL=https://api.luckyeventdj.com/api

# WhatsApp Number (without + or spaces)
VITE_WHATSAPP_NUMBER=15551234567

# Google Analytics ID (optional)
VITE_GA_ID=

# Enable/disable features
VITE_ENABLE_ANALYTICS=false
